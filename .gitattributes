# Auto-detect text files and normalize line endings
* text=auto eol=lf

# Always LF for shell scripts
*.sh   text eol=lf
*.cjs  text eol=lf
*.mjs  text eol=lf
*.ts   text eol=lf
*.tsx  text eol=lf
*.js   text eol=lf
*.json text eol=lf
*.md   text eol=lf
*.yml  text eol=lf
*.yaml text eol=lf
*.html text eol=lf
*.css  text eol=lf
*.svg  text eol=lf

# Windows-only
*.cmd  text eol=crlf
*.bat  text eol=crlf
*.ps1  text eol=crlf

# Binaries
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.ico  binary
*.icns binary
*.woff binary
*.woff2 binary
*.ttf  binary
*.otf  binary
*.zip  binary
*.7z   binary
*.exe  binary
*.dll  binary
*.dylib binary
*.so   binary
*.node binary
*.db   binary
*.sqlite binary

# Linguist hints (collapse generated / vendored stuff in PR diffs)
pnpm-lock.yaml linguist-generated=true
**/dist/**     linguist-generated=true
**/out/**      linguist-generated=true
examples/**    linguist-vendored=true
